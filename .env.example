# TripWeaver Environment Variables Template
# Copy this file to '.env' and fill in the values before running `docker-compose up`

# --------------------------
# Main Language Model Config
# --------------------------
OPENAI_API_KEY="sk-proj-your-openai-api-key-here"


# --------------------------
# Google Maps Transit Config
# --------------------------
# Optional: Used by transit_service to fetch real routes. If left empty or as "fake_key", 
# the service automatically defaults to a simulated dataset for testing.
GOOGLE_MAPS_API_KEY=""


# --------------------------
# Internal MCP Routing URLs 
# --------------------------
# DO NOT CHANGE THESE IF USING DOCKER COMPOSE. 
# Docker Compose will override these using internal DNS routing.
HOTEL_MCP_URL="http://localhost:8001/mcp"
FLIGHT_MCP_URL="http://localhost:8002/mcp"
WEATHER_MCP_URL="http://localhost:8004/mcp"
TRANSIT_MCP_URL="http://localhost:8005/mcp"

# Note: The frontend relies on VITE_API_BASE_URL internally, 
# you should set that in your Vercel Project Settings, not here.
